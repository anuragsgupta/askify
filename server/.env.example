# =============================================================================
# Askify RAG Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and configure your settings

# =============================================================================
# Gemini API Configuration (Primary - Higher Quality)
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for LLM (answer generation)
GEMINI_LLM_MODEL=gemini-3-flash-preview

# Gemini model for embeddings
GEMINI_EMBEDDING_MODEL=text-embedding-004

# =============================================================================
# Ollama Configuration (Fallback - Reliable)
# =============================================================================
# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama LLM model for answer generation
OLLAMA_LLM_MODEL=qwen3:4b-instruct-2507-q4_K_M

# Ollama embedding model
OLLAMA_EMBED_MODEL=nomic-embed-text

# =============================================================================
# Provider Priority
# =============================================================================
# Set to "true" to use Gemini as primary, "false" to use only Ollama
USE_GEMINI_PRIMARY=true

# =============================================================================
# ChromaDB Configuration
# =============================================================================
# ChromaDB persistence directory (default: ./chroma_data)
CHROMA_PERSIST_DIR=./chroma_data

# ChromaDB collection name (default: askify_docs)
CHROMA_COLLECTION_NAME=askify_docs

# =============================================================================
# Application Configuration
# =============================================================================
# Backend port (default: 8000)
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# =============================================================================
# Vector Search Accuracy Configuration
# =============================================================================
# Minimum relevance score (0.0-1.0) - filters out low-quality matches
# Higher values = more precise but may miss some results
# Lower values = more recall but may include irrelevant results
# Recommended: 0.65-0.75
MIN_RELEVANCE_SCORE=0.65

# Enable metadata-based boosting (recency, document type)
ENABLE_METADATA_BOOST=true

# Days to consider a document "recent" for boosting
RECENT_DAYS_THRESHOLD=30

# Boost factor for recent documents (1.0 = no boost, 1.2 = 20% boost)
RECENT_BOOST_FACTOR=1.2

# Boost factor for PDF/Excel documents (often more authoritative)
PDF_BOOST_FACTOR=1.1
