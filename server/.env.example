# =============================================================================
# Askify RAG Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and configure your settings

# =============================================================================
# Gemini API Configuration (Primary - Higher Quality)
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model for LLM (answer generation)
GEMINI_LLM_MODEL=gemini-3-flash-preview

# Gemini model for embeddings
GEMINI_EMBEDDING_MODEL=text-embedding-004

# =============================================================================
# Ollama Configuration (Fallback - Reliable)
# =============================================================================
# Ollama base URL (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Ollama LLM model for answer generation
OLLAMA_LLM_MODEL=qwen3:4b-instruct-2507-q4_K_M

# Ollama embedding model
OLLAMA_EMBED_MODEL=nomic-embed-text

# =============================================================================
# Provider Priority
# =============================================================================
# Set to "true" to use Gemini as primary, "false" to use only Ollama
USE_GEMINI_PRIMARY=true

# =============================================================================
# ChromaDB Configuration
# =============================================================================
# ChromaDB persistence directory (default: ./chroma_data)
CHROMA_PERSIST_DIR=./chroma_data

# ChromaDB collection name (default: askify_docs)
CHROMA_COLLECTION_NAME=askify_docs

# =============================================================================
# Application Configuration
# =============================================================================
# Backend port (default: 8000)
PORT=8000

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
